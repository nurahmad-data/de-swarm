# ============================================================
# de-swarm Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.template .env
#
# All providers offer free tiers. You only need ONE to start,
# but having 3+ enables the multi-provider failover logic.
# ============================================================

# ---------- LLM PROVIDER API KEYS ----------
# Get free keys from each provider's console:

# Mistral AI (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NVIDIA NIM (https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Cerebras (https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# GitHub Models (https://github.com/marketplace/models)
# Uses your GitHub Personal Access Token
GITHUB_TOKEN=your_github_pat_here

# SambaNova (https://cloud.sambanova.ai/)
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here


# ---------- PROVIDER SELECTION ----------
# Which provider to use as primary (mistral | openrouter | nvidia | cerebras | groq | github | sambanova | gemini)
LLM_PROVIDER=mistral

# Optional: dedicate specific providers to 3+ table queries
# These providers handle complex JOINs well
COMPLEX_QUERY_PROVIDERS=groq,github,sambanova,gemini


# ---------- MODEL NAMES (optional — defaults shown) ----------
MISTRAL_MODEL=mistral-large-latest
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
CEREBRAS_MODEL=llama3.1-70b
GROQ_MODEL=qwen-32b
GITHUB_MODEL=gpt-4o-mini
SAMBANOVA_MODEL=Qwen2.5-72B-Instruct
GEMINI_MODEL=gemini-1.5-flash


# ---------- RATE LIMITS (per provider, optional) ----------
# Format: PROVIDER_RPM=.requests_per_minute  PROVIDER_MIN_INTERVAL=seconds_between_requests
MISTRAL_RPM=3
MISTRAL_MIN_INTERVAL=20

OPENROUTER_RPM=20
OPENROUTER_MIN_INTERVAL=3

NVIDIA_RPM=40
NVIDIA_MIN_INTERVAL=1.5

CEREBRAS_RPM=3
CEREBRAS_MIN_INTERVAL=20

GROQ_RPM=30
GROQ_MIN_INTERVAL=2


# ---------- VALIDATION ----------
# Skip LLM semantic validation for faster generation (true | false)
# When true, only regex + SQLite EXPLAIN validation run (2 layers instead of 3)
SKIP_LLM_VALIDATION=false


# ---------- PROMPT FILE (for nightly_100.sh) ----------
# Which prompt file to use for batch generation
PROMPT_FILE=ecommerce_prompts.txt


# ---------- HUGGING FACE (for model upload) ----------
# Get token from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_USERNAME=nurahmad-data


# ---------- OLLAMA (for local inference) ----------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=de-sql-3b-v2


# ---------- KAGGLE (for training, optional) ----------
# Get from https://www.kaggle.com/settings/account
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key


# ---------- EVALUATION ----------
# Number of prompts per schema for eval (default: full)
EVAL_SAMPLE_SIZE=

# Random seed for prompt sampling (default: 42)
EVAL_SEED=42
